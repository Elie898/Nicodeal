{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "customerName": {
      "type": "string"
    },
    "customerEmail": {
      "type": "email"
    },
    "customerAddress": {
      "type": "text"
    },
    "totalPrice": {
      "type": "decimal"
    },
    "orderStatus": {
      "type": "enumeration",
      "default": "pending",
      "enum": [
        "pending",
        "confirmed",
        "shipped",
        "completed"
      ]
    },
    "orderItems": {
      "type": "component",
      "component": "order.order-item",
      "repeatable": true
    },
    "customerPhone": {
      "type": "string"
    },
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
